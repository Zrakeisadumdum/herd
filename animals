import java.util.ArrayList;
abstract class Livestock {
    String name;
    int age;
    public Livestock(String name, int age) {
        this.name = name;
        this.age = age;
    }
    abstract String makeSound();
    void graze() {
        System.out.println(name + " is grazing in the pasture.");
    }
    void graze(String food) {
        System.out.println(name + " is grazing on " + food + ".");
    }
}
interface WorkRole {
    String performTask();
}
class Horse extends Livestock implements WorkRole {
    public Horse(String name, int age) {
        super(name, age);
    }
    @Override
    String makeSound() {
        return "Yeehaw!";
    }
    @Override
    public String performTask() {
        return "Horse is used for riding and transportation.";
    }
}
class Sheep extends Livestock {
    public Sheep(String name, int age) {
        super(name, age);
    }
    @Override
    String makeSound() {
        return "Baa!";
    }
}
class Camel extends Livestock implements WorkRole {
    public Camel(String name, int age) {
        super(name, age);
    }
    @Override
    String makeSound() {
        return "Grunts!";
    }
    @Override
    public String performTask() {
        return "Camel is used for carrying loads and transportation in desert areas.";
    }
}
class Goat extends Livestock implements WorkRole {
    public Goat(String name, int age) {
        super(name, age);
    }

    @Override
    String makeSound() {
        return "Maa!";
    }

    @Override
    public String performTask() {
        return "Goat is used for milk and meat production.";
    }
    String makeSound(int volume) {
        return "Maa!".repeat(volume);
    }
}
class Cow extends Livestock implements WorkRole {
    public Cow(String name, int age) {
        super(name, age);
    }
    @Override
    String makeSound() {
        return "Moo!";
    }
    @Override
    public String performTask() {
        return "Cow is used for milk production and meat production.";
    }
}
class Herd {
    ArrayList<Livestock> livestock = new ArrayList<>();
    void addLivestock(Livestock animal) {
        livestock.add(animal);
    }
    void dailyRoutine() {
        for (Livestock animal : livestock) {
            System.out.println(animal.name + ": " + animal.makeSound());
            if (animal instanceof WorkRole) {
                System.out.println(((WorkRole) animal).performTask());
            }
        }
    }
}
public class NomadLivestockDemo {
    public static void main(String[] args) {
        Herd herd = new Herd();
        herd.addLivestock(new Horse("Herald", 4));
        herd.addLivestock(new Sheep("Fluffybun", 2));
        herd.addLivestock(new Camel("Gramps", 6));
        herd.addLivestock(new Goat("The Goat", 3));
        herd.addLivestock(new Cow("Callie", 5));
        herd.dailyRoutine();
        Livestock[] animals = {
            new Horse("Herald", 5),
            new Sheep("Fluffybun", 2),
            new Goat("The Goat", 3)
        };
        for (Livestock a : animals) {
            a.graze(); 
        }
        Goat g = new Goat("The Goat", 2);
        System.out.println(g.makeSound(3));
    }
}
